package aiss.dailymotion_Miner.mapper;

public class DailymotionMapper {

    public VMVideo toVideo(Video video, VMUser user, List<VMCaption< captions) {

        List<VMComment> comments = !video.getHashtags().isEmpty() ? toComment(video): new ArrayList<>();

        VMVideo vmvideo = new VMVideo(
            video.getId(),
            video.getTitle(),
            video.getDescription(),
            video.getCreatedTime().toString(),
            captions,
            comments,
            user
        );
        
        return vmvideo;
    }

